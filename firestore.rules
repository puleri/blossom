rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function isPlayer(gameId) {
      return isAuthed()
        && exists(/databases/$(database)/documents/games/$(gameId)/players/$(request.auth.uid));
    }

    function isHost(gameId) {
      return isPlayer(gameId)
        && get(/databases/$(database)/documents/games/$(gameId)/players/$(request.auth.uid)).data.isHost == true;
    }

    function criticalGameFieldsUnchanged() {
      return request.resource.data.status == resource.data.status
        && request.resource.data.phase == resource.data.phase
        && request.resource.data.eventDeck == resource.data.eventDeck
        && request.resource.data.currentEvent == resource.data.currentEvent
        && request.resource.data.currentEventId == resource.data.currentEventId
        && request.resource.data.playerOrder == resource.data.playerOrder
        && request.resource.data.turnIndex == resource.data.turnIndex;
    }

    function selfPlayerWriteAllowedFieldsOnly() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'displayName',
        'resources',
        'hand',
        'gardenSlots',
        'keptFromMulligan',
        'score'
      ]);
    }

    match /games/{gameId} {
      allow read: if isPlayer(gameId);

      allow create: if isAuthed() && request.resource.data.createdBy == request.auth.uid;

      allow update: if isPlayer(gameId)
        && (isHost(gameId) || criticalGameFieldsUnchanged());

      allow delete: if isHost(gameId);

      match /players/{uid} {
        allow read: if isPlayer(gameId);

        allow create: if isHost(gameId)
          || (isAuthed()
            && request.auth.uid == uid
            && request.resource.data.uid == uid
            && request.resource.data.isHost == false);

        allow update: if isHost(gameId)
          || (isAuthed()
            && request.auth.uid == uid
            && selfPlayerWriteAllowedFieldsOnly());

        allow delete: if isHost(gameId);
      }

      match /log/{entryId} {
        allow read: if isPlayer(gameId);
        allow create: if isPlayer(gameId);
      }
    }
  }
}
